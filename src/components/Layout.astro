---
import "../styles/global.css";
import Navbar from "./Navbar.astro";
import Footer from "./Footer.astro";
import { company } from "../data/company";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath = Astro.url.pathname } = Astro.props;
const pageTitle = title === company.name ? title : `${title} | ${company.name}`;
const canonical = `https://${company.domain}${canonicalPath}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7fbf8" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`https://${company.domain}/og/friday.png`} />
    <slot name="head" />
  </head>
  <body class="font-sans antialiased">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
