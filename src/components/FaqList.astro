---
interface Faq {
  question: string;
  answer: string;
}

interface Props {
  items: Faq[];
}

const { items } = Astro.props;
---

<div class="divide-y divide-ink/10 rounded-2xl border border-ink/10 bg-white">
  {items.map((item) => (
    <details class="group p-5">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-semibold text-ink">
        {item.question}
        <span class="text-xl text-leaf transition group-open:rotate-45">+</span>
      </summary>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-ink/64">{item.answer}</p>
    </details>
  ))}
</div>
