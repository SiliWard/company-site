---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
}

const { eyebrow, title, text } = Astro.props;
---

<div class="mx-auto max-w-3xl text-center">
  {eyebrow && <p class="text-sm font-semibold uppercase tracking-wider text-leaf">{eyebrow}</p>}
  <h2 class="mt-3 text-3xl font-semibold tracking-normal text-ink md:text-4xl">{title}</h2>
  {text && <p class="mt-4 text-base leading-7 text-ink/64">{text}</p>}
</div>
