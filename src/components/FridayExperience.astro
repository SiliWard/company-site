---
const steps = [
  {
    id: "capture",
    label: "AI 记录",
    title: "把一句话整理成待办草案",
    input: "明天下午三点前整理官网下载页和版本说明",
    output: "明天 15:00 前完成官网下载页与版本说明核对",
    meta: "等待确认"
  },
  {
    id: "calendar",
    label: "日历排程",
    title: "确认后进入日历视图",
    input: "拖动任务块即可调整日期和持续时间",
    output: "官网发布检查 · 明天 13:30-15:00",
    meta: "已排程"
  },
  {
    id: "selection",
    label: "划词工具",
    title: "对选中文本做总结或翻译",
    input: "Release assets include Windows installer and blockmap.",
    output: "发布资产包含 Windows 安装包和更新 blockmap。",
    meta: "本地弹窗"
  },
  {
    id: "codex",
    label: "Codex",
    title: "把文件篮交给独立工作流",
    input: "src/pages/download.astro, src/data/releases.ts",
    output: "创建隔离任务，生成变更计划，等待用户批准命令。",
    meta: "默认关闭"
  }
];
---

<section class="section-shell py-20">
  <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wider text-leaf">Interactive preview</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-normal text-ink md:text-4xl">快速体验 Friday 的工作方式</h2>
      <p class="mt-4 text-sm leading-6 text-ink/64">从一句自然语言开始，Friday 会把记录、排程、划词处理和 Codex 工作流放在同一个桌面入口里。</p>
      <div class="mt-7 grid gap-2 sm:grid-cols-2 lg:grid-cols-1" role="tablist" aria-label="Friday feature preview">
        {steps.map((step, index) => (
          <button
            type="button"
            class={`friday-preview-tab focus-ring rounded-xl border px-4 py-3 text-left transition ${index === 0 ? "border-leaf bg-mint text-ink" : "border-ink/10 bg-white text-ink/72 hover:border-leaf"}`}
            data-preview-tab={step.id}
            aria-selected={index === 0 ? "true" : "false"}
          >
            <span class="block text-sm font-semibold">{step.label}</span>
            <span class="mt-1 block text-xs leading-5 text-ink/56">{step.title}</span>
          </button>
        ))}
      </div>
    </div>

    <div class="rounded-2xl border border-ink/10 bg-white shadow-soft">
      <div class="flex items-center justify-between border-b border-ink/10 px-5 py-4">
        <div class="flex items-center gap-2">
          <span class="h-3 w-3 rounded-full bg-red-400"></span>
          <span class="h-3 w-3 rounded-full bg-ember"></span>
          <span class="h-3 w-3 rounded-full bg-moss"></span>
        </div>
        <span id="friday-preview-meta" class="rounded-full bg-cloud px-3 py-1 text-xs font-semibold text-leaf">{steps[0].meta}</span>
      </div>
      <div class="grid gap-0 md:grid-cols-[0.72fr_1.28fr]">
        <aside class="border-b border-ink/10 bg-ink p-5 text-white md:border-b-0 md:border-r">
          <div class="flex items-center gap-3">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-moss text-lg font-semibold text-ink">F</div>
            <div>
              <p class="text-sm font-semibold">Friday</p>
              <p class="text-xs text-white/58">桌面助手</p>
            </div>
          </div>
          <div class="mt-6 space-y-2">
            {["记录", "待办", "日历", "划词", "Codex"].map((item, index) => (
              <div class={`rounded-lg px-3 py-2 text-sm ${index === 0 ? "bg-white text-ink" : "bg-white/8 text-white/72"}`}>{item}</div>
            ))}
          </div>
        </aside>
        <div class="p-5">
          <p id="friday-preview-title" class="text-xs font-semibold uppercase tracking-wider text-leaf">{steps[0].title}</p>
          <div class="mt-4 rounded-xl bg-cloud p-4">
            <p class="text-xs font-semibold text-ink/44">Input</p>
            <p id="friday-preview-input" class="mt-2 min-h-12 text-sm leading-6 text-ink/72">{steps[0].input}</p>
          </div>
          <div class="mt-4 rounded-xl border border-ink/10 p-4">
            <div class="flex items-center justify-between gap-3">
              <p class="text-xs font-semibold text-ink/44">Friday draft</p>
              <span class="rounded-full bg-mint px-2.5 py-1 text-xs font-semibold text-leaf">Ready</span>
            </div>
            <p id="friday-preview-output" class="mt-3 min-h-16 text-base leading-7 text-ink">{steps[0].output}</p>
          </div>
          <div class="mt-4 grid grid-cols-3 gap-3">
            <div class="rounded-lg bg-mint p-3 text-center">
              <p class="text-xs text-ink/48">Tasks</p>
              <p class="mt-1 text-lg font-semibold text-ink">12</p>
            </div>
            <div class="rounded-lg bg-cloud p-3 text-center">
              <p class="text-xs text-ink/48">Today</p>
              <p class="mt-1 text-lg font-semibold text-ink">4</p>
            </div>
            <div class="rounded-lg bg-cloud p-3 text-center">
              <p class="text-xs text-ink/48">Local</p>
              <p class="mt-1 text-lg font-semibold text-ink">On</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const steps = [
    {
      id: "capture",
      title: "把一句话整理成待办草案",
      input: "明天下午三点前整理官网下载页和版本说明",
      output: "明天 15:00 前完成官网下载页与版本说明核对",
      meta: "等待确认"
    },
    {
      id: "calendar",
      title: "确认后进入日历视图",
      input: "拖动任务块即可调整日期和持续时间",
      output: "官网发布检查 · 明天 13:30-15:00",
      meta: "已排程"
    },
    {
      id: "selection",
      title: "对选中文本做总结或翻译",
      input: "Release assets include Windows installer and blockmap.",
      output: "发布资产包含 Windows 安装包和更新 blockmap。",
      meta: "本地弹窗"
    },
    {
      id: "codex",
      title: "把文件篮交给独立工作流",
      input: "src/pages/download.astro, src/data/releases.ts",
      output: "创建隔离任务，生成变更计划，等待用户批准命令。",
      meta: "默认关闭"
    }
  ];

  const tabs = Array.from(document.querySelectorAll("[data-preview-tab]"));
  const title = document.getElementById("friday-preview-title");
  const input = document.getElementById("friday-preview-input");
  const output = document.getElementById("friday-preview-output");
  const meta = document.getElementById("friday-preview-meta");

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const selected = steps.find((step) => step.id === tab.dataset.previewTab);
      if (!selected || !title || !input || !output || !meta) return;

      tabs.forEach((item) => {
        item.setAttribute("aria-selected", "false");
        item.classList.remove("border-leaf", "bg-mint", "text-ink");
        item.classList.add("border-ink/10", "bg-white", "text-ink/72");
      });

      tab.setAttribute("aria-selected", "true");
      tab.classList.add("border-leaf", "bg-mint", "text-ink");
      tab.classList.remove("border-ink/10", "bg-white", "text-ink/72");

      title.textContent = selected.title;
      input.textContent = selected.input;
      output.textContent = selected.output;
      meta.textContent = selected.meta;
    });
  });
</script>
