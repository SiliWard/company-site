---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class={`product-screen relative overflow-hidden rounded-2xl border border-ink/10 shadow-soft ${compact ? "p-4" : "p-5 md:p-6"}`} aria-label="Friday product preview">
  <div class="flex items-center justify-between border-b border-ink/10 pb-4">
    <div class="flex items-center gap-2">
      <span class="h-3 w-3 rounded-full bg-red-400"></span>
      <span class="h-3 w-3 rounded-full bg-ember"></span>
      <span class="h-3 w-3 rounded-full bg-moss"></span>
    </div>
    <span class="rounded-full bg-mint px-3 py-1 text-xs font-semibold text-leaf">Friday Workspace</span>
  </div>
  <div class="grid gap-4 pt-5 md:grid-cols-[0.85fr_1.25fr]">
    <aside class="rounded-xl bg-ink p-4 text-white">
      <div class="flex items-center gap-3">
        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-moss text-xl">F</div>
        <div>
          <p class="text-sm font-semibold">Friday</p>
          <p class="text-xs text-white/58">桌面助手在线</p>
        </div>
      </div>
      <div class="mt-5 space-y-2">
        {["对话", "待办", "日历", "总结", "设置"].map((item, index) => (
          <div class={`rounded-lg px-3 py-2 text-sm ${index === 1 ? "bg-white text-ink" : "bg-white/8 text-white/76"}`}>{item}</div>
        ))}
      </div>
    </aside>
    <section class="space-y-4">
      <div class="rounded-xl border border-ink/10 bg-white p-4">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-leaf">Today</p>
            <h3 class="mt-1 text-xl font-semibold text-ink">把零散想法变成任务</h3>
          </div>
          <span class="rounded-full bg-mint px-3 py-1 text-xs text-leaf">3 reminders</span>
        </div>
        <div class="mt-4 grid gap-3">
          {["16:00 准备产品发布清单", "18:30 检查 Windows 安装包签名", "明早 跟进隐私政策终稿"].map((item) => (
            <div class="flex items-center gap-3 rounded-lg bg-cloud p-3">
              <span class="h-2.5 w-2.5 rounded-full bg-moss"></span>
              <span class="text-sm text-ink/72">{item}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-ink/10 bg-white p-4">
          <p class="text-sm font-semibold text-ink">AI 草案</p>
          <p class="mt-2 text-sm leading-6 text-ink/60">“下周上线前检查下载页和 FAQ”</p>
        </div>
        <div class="rounded-xl border border-ink/10 bg-white p-4">
          <p class="text-sm font-semibold text-ink">权限状态</p>
          <p class="mt-2 text-sm leading-6 text-ink/60">选区工具和 Codex 默认关闭</p>
        </div>
      </div>
    </section>
  </div>
</div>
