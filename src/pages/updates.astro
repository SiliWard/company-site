---
import Layout from "../components/Layout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import { getWindowsReleases } from "../data/releases";

const releases = await getWindowsReleases();
---

<Layout title="Updates" description="Friday release notes and update history." canonicalPath="/updates">
  <section class="section-shell py-16">
    <p class="text-sm font-semibold uppercase tracking-wider text-leaf">Release notes</p>
    <h1 class="mt-4 text-4xl font-semibold text-ink md:text-5xl">版本更新</h1>
    <div class="mt-10 space-y-5">
      {releases.map((release) => (
        <article class="rounded-2xl border border-ink/10 bg-white p-6">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
            <h2 class="text-2xl font-semibold text-ink">Friday {release.version}</h2>
            <time class="text-sm text-ink/52">{release.date}</time>
          </div>
          {release.notes.length > 0 && (
            <ul class="mt-5 space-y-3">
              {release.notes.map((item) => <li class="text-sm leading-6 text-ink/68">✓ {item}</li>)}
            </ul>
          )}
          <div class="mt-6 flex flex-col gap-3 border-t border-ink/10 pt-5 sm:flex-row sm:items-center sm:justify-between">
            <p class="break-all text-sm text-ink/60">{release.exe.name} · {release.exe.sizeLabel}</p>
            <ButtonLink href={release.exe.url} variant="secondary">下载 exe</ButtonLink>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
