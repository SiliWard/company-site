---
import Layout from "../components/Layout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import friday from "../data/products/friday.json";
import { characterPacksUrl, getCharacterPacks } from "../data/characterPacks";
import { getWindowsReleases, releasesUrl } from "../data/releases";

const releases = await getWindowsReleases();
const latest = releases[0];
const characterPacks = await getCharacterPacks();
---

<Layout title="Download Friday" description="Download Friday for Windows and review version, signature, checksum, and system requirements." canonicalPath="/download">
  <section class="section-shell py-16">
    <div class="grid gap-10 rounded-3xl border border-ink/10 bg-white p-8 shadow-soft md:grid-cols-[1fr_0.8fr] md:p-10">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-leaf">Download</p>
        <h1 class="mt-4 text-4xl font-semibold text-ink md:text-5xl">下载 Friday for Windows</h1>
        <p class="mt-5 max-w-2xl text-base leading-7 text-ink/64">最新安装包来自 GitHub Releases。历史版本保留对应的 Windows exe，便于回退和核对版本。</p>
        <div class="mt-8">
          <ButtonLink href={latest.exe.url}>下载最新安装包</ButtonLink>
        </div>
      </div>
      <dl class="grid gap-4 rounded-2xl bg-cloud p-6">
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wider text-ink/44">Version</dt>
          <dd class="mt-1 text-lg font-semibold text-ink">{latest.version}</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wider text-ink/44">Platform</dt>
          <dd class="mt-1 text-lg font-semibold text-ink">{friday.platform}</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wider text-ink/44">Installer</dt>
          <dd class="mt-1 break-all text-sm text-ink/68">{latest.exe.name}</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wider text-ink/44">Size</dt>
          <dd class="mt-1 text-sm text-ink/68">{latest.exe.sizeLabel}</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="section-shell py-12">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-leaf">Character packs</p>
        <h2 class="mt-3 text-3xl font-semibold text-ink">角色包下载</h2>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-ink/64">下载 zip 后解压，在 Friday 设置中选择对应的 <span class="font-semibold text-ink">角色名_state</span> 文件夹即可导入。</p>
      </div>
      <a class="focus-ring rounded-md text-sm font-semibold text-leaf underline-offset-4 hover:underline" href={characterPacksUrl}>
        查看角色包 Releases
      </a>
    </div>
    <div class="mt-8 grid gap-5 lg:grid-cols-[1fr_0.72fr]">
      <div class="grid gap-4">
        {characterPacks.map((pack) => (
          <article class="rounded-2xl border border-ink/10 bg-white p-5 shadow-sm">
            <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
              <div>
                <div class="flex flex-wrap items-center gap-3">
                  <h3 class="text-xl font-semibold text-ink">{pack.name}</h3>
                  <span class="rounded-full bg-mint px-3 py-1 text-xs font-semibold text-leaf">v{pack.version}</span>
                  <time class="text-sm text-ink/52">{pack.date}</time>
                </div>
                <p class="mt-2 break-all text-sm text-ink/60">{pack.file.name} · {pack.file.sizeLabel}</p>
              </div>
              <ButtonLink href={pack.file.url}>下载角色包</ButtonLink>
            </div>
          </article>
        ))}
      </div>
      <article class="rounded-2xl border border-leaf/20 bg-mint p-6">
        <h3 class="text-xl font-semibold text-ink">制作自己的角色包</h3>
        <p class="mt-3 text-sm leading-6 text-ink/64">准备 10 张状态图后，可以用角色查看器统一裁剪、预览效果，并导出 Friday 可识别的角色文件夹。</p>
        <div class="mt-5">
          <ButtonLink href="/tools/friday-character" variant="secondary">打开角色查看器</ButtonLink>
        </div>
      </article>
    </div>
  </section>

  <section class="section-shell py-12">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-leaf">Release archive</p>
        <h2 class="mt-3 text-3xl font-semibold text-ink">历史版本</h2>
      </div>
      <a class="focus-ring rounded-md text-sm font-semibold text-leaf underline-offset-4 hover:underline" href={releasesUrl}>
        查看 GitHub Releases
      </a>
    </div>
    <div class="mt-8 divide-y divide-ink/10 rounded-2xl border border-ink/10 bg-white">
      {releases.map((release) => (
        <article class="grid gap-4 p-5 md:grid-cols-[1fr_auto] md:items-center">
          <div>
            <div class="flex flex-wrap items-center gap-3">
              <h3 class="text-xl font-semibold text-ink">Friday {release.version}</h3>
              <time class="text-sm text-ink/52">{release.date}</time>
            </div>
            <p class="mt-2 break-all text-sm text-ink/60">{release.exe.name} · {release.exe.sizeLabel}</p>
          </div>
          <ButtonLink href={release.exe.url} variant="secondary">下载 exe</ButtonLink>
        </article>
      ))}
    </div>
  </section>

  <section class="section-shell grid gap-5 py-12 md:grid-cols-3">
    {[
      ["代码签名", "正式公开版使用公司 Windows 代码签名证书，下载页同步展示发布者和校验方式。"],
      ["SmartScreen", "新证书早期可能触发 Windows 提示，页面会提供签名和校验说明帮助用户判断。"],
      ["系统要求", "Windows 10/11 x64，部分全局选区能力依赖系统权限和用户主动开启。"]
    ].map(([title, text]) => (
      <article class="rounded-2xl border border-ink/10 bg-white p-6">
        <h2 class="text-xl font-semibold text-ink">{title}</h2>
        <p class="mt-3 text-sm leading-6 text-ink/64">{text}</p>
      </article>
    ))}
  </section>
</Layout>
