---
import Layout from "../components/Layout.astro";
import ButtonLink from "../components/ButtonLink.astro";
---

<Layout title="Not Found" description="Page not found." canonicalPath="/404">
  <section class="section-shell flex min-h-[60vh] flex-col items-center justify-center py-16 text-center">
    <p class="text-sm font-semibold uppercase tracking-wider text-leaf">404</p>
    <h1 class="mt-4 text-4xl font-semibold text-ink md:text-5xl">页面不存在</h1>
    <p class="mt-5 max-w-xl text-base leading-7 text-ink/64">这个链接可能已经移动，或当前版本还没有发布。</p>
    <div class="mt-8">
      <ButtonLink href="/">回到首页</ButtonLink>
    </div>
  </section>
</Layout>
