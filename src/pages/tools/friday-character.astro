---
import "cropperjs/dist/cropper.css";
import Layout from "../../components/Layout.astro";
import SectionHeading from "../../components/SectionHeading.astro";

const states = [
  ["Idle", "默认待机", "常驻桌面时的基础形态。"],
  ["Talking", "对话输入", "用户正在和 Friday 交流。"],
  ["Happy", "完成反馈", "任务完成或操作成功后的正向反馈。"],
  ["Thinking", "整理思考", "AI 正在生成草案或整理上下文。"],
  ["Reminder", "提醒触发", "提醒到来时的提示状态。"],
  ["Confused", "需要确认", "输入不清晰或需要用户补充。"],
  ["Dragging", "拖拽移动", "用户拖动桌面助手时显示。"],
  ["Urgent", "紧急事项", "存在过期或高优先级任务。"],
  ["Rest", "低干扰休息", "长时间空闲后的放松状态。"],
  ["Sleepy", "深度空闲", "更久未互动时降低存在感。"]
] as const;
---

<Layout title="Friday 角色查看器" description="在线裁剪、预览并打包可导入 Friday 的桌面助手角色文件夹。" canonicalPath="/tools/friday-character">
  <section class="section-shell py-14">
    <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
      <SectionHeading
        eyebrow="Friday Character Tool"
        title="制作可导入 Friday 的角色文件夹"
        text="准备 10 张规定状态图片，统一裁剪尺寸、预览状态切换效果，满意后下载 zip。图片只在浏览器本地处理，不会上传。"
      />
      <div class="rounded-lg border border-ink/10 bg-white p-5 shadow-sm">
        <div class="grid gap-4 sm:grid-cols-[1fr_120px_120px]">
          <label class="grid gap-2 text-sm font-semibold text-ink">
            角色名
            <input id="roleName" class="focus-ring rounded-lg border border-ink/12 bg-cloud px-3 py-2 text-sm font-medium outline-none" value="Custom" />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-ink">
            宽度
            <input id="outputWidth" class="focus-ring rounded-lg border border-ink/12 bg-cloud px-3 py-2 text-sm font-medium outline-none" type="number" min="128" max="4096" step="64" value="1024" />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-ink">
            高度
            <input id="outputHeight" class="focus-ring rounded-lg border border-ink/12 bg-cloud px-3 py-2 text-sm font-medium outline-none" type="number" min="128" max="4096" step="64" value="1024" />
          </label>
        </div>
        <p id="packageName" class="mt-4 rounded-lg bg-mint px-4 py-3 text-sm font-semibold text-leaf">导出文件夹：Custom_state｜输出尺寸：1024 x 1024 PNG</p>
      </div>
    </div>
  </section>

  <section class="bg-white py-12">
    <div class="section-shell grid gap-8 xl:grid-cols-[320px_minmax(0,1fr)_320px]">
      <aside>
        <div class="mb-4 flex items-center justify-between gap-3">
          <h2 class="text-xl font-semibold text-ink">状态图片</h2>
          <div class="flex items-center gap-2">
            <span id="uploadCount" class="rounded-full bg-cloud px-3 py-1 text-xs font-semibold text-ink/60">0 / 10</span>
            <button id="clearAllImages" class="focus-ring rounded-lg border border-ink/10 bg-white px-3 py-1.5 text-xs font-semibold text-ink/60 transition hover:border-leaf hover:text-leaf disabled:cursor-not-allowed disabled:text-ink/25" type="button" disabled>
              清除全部
            </button>
          </div>
        </div>
        <div class="grid gap-3">
          {states.map(([name, label, help]) => (
            <article class="state-card rounded-lg border border-ink/10 bg-cloud p-3" data-state={name}>
              <div class="flex items-start justify-between gap-3">
                <div>
                  <h3 class="text-sm font-semibold text-ink">_{name}_</h3>
                  <p class="mt-1 text-xs font-semibold text-leaf">{label}</p>
                </div>
                <span class="state-status rounded-full bg-white px-2 py-1 text-xs font-semibold text-ink/45">缺失</span>
              </div>
              <p class="mt-2 text-xs leading-5 text-ink/58">{help}</p>
              <div class="mt-3 grid grid-cols-[56px_1fr] gap-3">
                <div class="grid h-14 w-14 place-items-center overflow-hidden rounded-lg bg-white">
                  <img class="state-thumb hidden h-full w-full object-contain" alt={`${name} preview`} />
                  <span class="state-empty text-xs font-semibold text-ink/30">PNG</span>
                </div>
                <div class="grid gap-2">
                  <label class="focus-ring inline-flex min-h-9 cursor-pointer items-center justify-center rounded-lg bg-white px-3 text-xs font-semibold text-ink shadow-sm transition hover:text-leaf">
                    上传图片
                    <input class="sr-only state-input" type="file" accept="image/png,image/jpeg,image/webp,image/gif,image/avif" data-state={name} />
                  </label>
                  <button class="focus-ring state-select min-h-9 rounded-lg border border-ink/10 bg-white px-3 text-xs font-semibold text-ink/70 transition hover:border-leaf hover:text-leaf" type="button" data-state={name}>
                    编辑裁剪
                  </button>
                  <button class="focus-ring clear-state min-h-9 rounded-lg border border-ink/10 bg-white px-3 text-xs font-semibold text-ink/55 transition hover:border-leaf hover:text-leaf disabled:cursor-not-allowed disabled:text-ink/25" type="button" data-state={name} disabled>
                    清除图片
                  </button>
                </div>
              </div>
            </article>
          ))}
        </div>
      </aside>

      <section class="min-w-0">
        <div class="mb-4 flex flex-col justify-between gap-3 md:flex-row md:items-center">
          <div>
            <h2 id="editorTitle" class="text-xl font-semibold text-ink">裁剪编辑器</h2>
            <p id="editorHint" class="mt-1 text-sm text-ink/60">先上传 Idle 图片，再设置统一裁剪框。</p>
          </div>
          <div class="flex flex-wrap gap-2">
            <button id="saveGlobalCrop" class="focus-ring rounded-lg bg-leaf px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-ink" type="button" disabled>
              保存为统一裁剪
            </button>
            <button id="saveStateCrop" class="focus-ring rounded-lg border border-ink/12 bg-white px-4 py-2 text-sm font-semibold text-ink shadow-sm transition hover:border-leaf hover:text-leaf" type="button" disabled>
              保存单张微调
            </button>
            <button id="clearStateCrop" class="focus-ring rounded-lg border border-ink/12 bg-white px-4 py-2 text-sm font-semibold text-ink shadow-sm transition hover:border-leaf hover:text-leaf" type="button" disabled>
              清除微调
            </button>
          </div>
        </div>

        <div class="overflow-hidden rounded-lg border border-ink/10 bg-cloud p-4">
          <div id="cropperEmpty" class="grid min-h-[420px] place-items-center rounded-lg border border-dashed border-ink/16 bg-white text-center">
            <div>
              <p class="text-lg font-semibold text-ink">上传一张状态图开始裁剪</p>
              <p class="mt-2 text-sm text-ink/58">建议每个状态的角色站位接近，导出后切换更稳定。</p>
            </div>
          </div>
          <div id="cropperWrap" class="hidden rounded-lg bg-white">
            <img id="cropperImage" class="block max-h-[560px] w-full object-contain" alt="当前裁剪图片" />
          </div>
        </div>

        <div class="mt-4 grid gap-4 md:grid-cols-3">
          <div class="rounded-lg border border-ink/10 bg-white p-4">
            <p class="text-xs font-semibold uppercase tracking-wider text-ink/40">Unified crop</p>
            <p id="globalCropStatus" class="mt-2 text-sm font-semibold text-ink">尚未保存</p>
          </div>
          <div class="rounded-lg border border-ink/10 bg-white p-4">
            <p class="text-xs font-semibold uppercase tracking-wider text-ink/40">Current state</p>
            <p id="activeStateStatus" class="mt-2 text-sm font-semibold text-ink">Idle</p>
          </div>
          <div class="rounded-lg border border-ink/10 bg-white p-4">
            <p class="text-xs font-semibold uppercase tracking-wider text-ink/40">Missing</p>
            <p id="missingStatus" class="mt-2 text-sm font-semibold text-ink">10 个状态未上传</p>
          </div>
        </div>
      </section>

      <aside>
        <div class="sticky top-24 rounded-lg border border-ink/10 bg-cloud p-5">
          <div class="flex items-center justify-between gap-3">
            <h2 class="text-xl font-semibold text-ink">导入预览</h2>
            <button id="toggleAutoPreview" class="focus-ring rounded-lg border border-ink/12 bg-white px-3 py-2 text-xs font-semibold text-ink shadow-sm transition hover:border-leaf hover:text-leaf" type="button">
              自动轮播
            </button>
          </div>
          <div class="mt-5 grid min-h-72 place-items-center rounded-lg bg-white p-4">
            <img id="petPreview" class="hidden max-h-64 w-full object-contain drop-shadow-xl" alt="Friday 角色导入预览" />
            <p id="previewEmpty" class="text-center text-sm font-semibold text-ink/45">上传图片后查看裁剪效果</p>
          </div>
          <div class="mt-4 grid grid-cols-2 gap-2">
            {states.map(([name]) => (
              <button class="preview-state focus-ring rounded-lg border border-ink/10 bg-white px-3 py-2 text-xs font-semibold text-ink/68 transition hover:border-leaf hover:text-leaf" type="button" data-state={name}>
                {name}
              </button>
            ))}
          </div>
          <button id="downloadZip" class="focus-ring mt-5 inline-flex min-h-11 w-full items-center justify-center rounded-lg bg-leaf px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-ink disabled:cursor-not-allowed disabled:bg-ink/25" type="button" disabled>
            下载角色 zip
          </button>
          <p id="downloadHint" class="mt-3 text-xs leading-5 text-ink/58">上传 10 张状态图后即可下载。</p>
        </div>
      </aside>
    </div>
  </section>

  <script>
    // @ts-nocheck
    import Cropper from "cropperjs";
    import JSZip from "jszip";

    const states = [
      "Idle",
      "Talking",
      "Happy",
      "Thinking",
      "Reminder",
      "Confused",
      "Dragging",
      "Urgent",
      "Rest",
      "Sleepy"
    ];

    const files = {};
    const sourceUrls = {};
    const imageSizes = {};
    const cropOverrides = {};
    let activeState = "Idle";
    let globalCrop = null;
    let cropper = null;
    let autoTimer = 0;
    let previewState = "Idle";
    let previewObjectUrl = "";

    const roleNameInput = document.querySelector("#roleName");
    const outputWidthInput = document.querySelector("#outputWidth");
    const outputHeightInput = document.querySelector("#outputHeight");
    const packageName = document.querySelector("#packageName");
    const uploadCount = document.querySelector("#uploadCount");
    const editorTitle = document.querySelector("#editorTitle");
    const editorHint = document.querySelector("#editorHint");
    const cropperEmpty = document.querySelector("#cropperEmpty");
    const cropperWrap = document.querySelector("#cropperWrap");
    const cropperImage = document.querySelector("#cropperImage");
    const saveGlobalCrop = document.querySelector("#saveGlobalCrop");
    const saveStateCrop = document.querySelector("#saveStateCrop");
    const clearStateCrop = document.querySelector("#clearStateCrop");
    const globalCropStatus = document.querySelector("#globalCropStatus");
    const activeStateStatus = document.querySelector("#activeStateStatus");
    const missingStatus = document.querySelector("#missingStatus");
    const petPreview = document.querySelector("#petPreview");
    const previewEmpty = document.querySelector("#previewEmpty");
    const downloadZip = document.querySelector("#downloadZip");
    const downloadHint = document.querySelector("#downloadHint");
    const toggleAutoPreview = document.querySelector("#toggleAutoPreview");
    const clearAllImages = document.querySelector("#clearAllImages");
    let previewVersion = 0;

    function sanitizeRoleName(value) {
      const normalized = value.trim().replace(/[<>:"/\\|?*\x00-\x1f]+/g, "_").replace(/\s+/g, "_").replace(/^_+|_+$/g, "");
      return normalized || "Custom";
    }

    function folderName() {
      return `${sanitizeRoleName(roleNameInput.value)}_state`;
    }

    function outputSize() {
      const width = Math.min(4096, Math.max(128, Number(outputWidthInput.value) || 1024));
      const height = Math.min(4096, Math.max(128, Number(outputHeightInput.value) || 1024));
      return { width, height };
    }

    function updatePackageName() {
      const { width, height } = outputSize();
      packageName.textContent = `导出文件夹：${folderName()}｜输出尺寸：${width} x ${height} PNG`;
    }

    function uploadedStates() {
      return states.filter((state) => files[state]);
    }

    function missingStates() {
      return states.filter((state) => !files[state]);
    }

    function setActiveState(state) {
      activeState = state;
      editorTitle.textContent = `裁剪编辑器：_${state}_`;
      activeStateStatus.textContent = cropOverrides[state] ? `${state}（已单张微调）` : state;
      document.querySelectorAll(".state-card").forEach((card) => {
        card.classList.toggle("border-leaf", card.dataset.state === state);
      });
      loadCropperForActiveState();
    }

    function cropperDataToRatio() {
      if (!cropper || !imageSizes[activeState]) return null;
      const data = cropper.getData(true);
      const size = imageSizes[activeState];
      return {
        x: data.x / size.width,
        y: data.y / size.height,
        width: data.width / size.width,
        height: data.height / size.height
      };
    }

    function ratioToData(ratio, state) {
      const size = imageSizes[state];
      if (!ratio || !size) return null;
      return {
        x: ratio.x * size.width,
        y: ratio.y * size.height,
        width: ratio.width * size.width,
        height: ratio.height * size.height
      };
    }

    function loadCropperForActiveState() {
      if (cropper) {
        cropper.destroy();
        cropper = null;
      }

      const url = sourceUrls[activeState];
      const hasImage = Boolean(url);
      cropperEmpty.classList.toggle("hidden", hasImage);
      cropperWrap.classList.toggle("hidden", !hasImage);
      saveGlobalCrop.disabled = !hasImage;
      saveStateCrop.disabled = !hasImage;
      clearStateCrop.disabled = !cropOverrides[activeState];

      if (!hasImage) {
        editorHint.textContent = `上传 _${activeState}_ 图片后可以编辑裁剪。`;
        cropperImage.removeAttribute("src");
        return;
      }

      editorHint.textContent = cropOverrides[activeState]
        ? "当前状态使用单张微调裁剪。"
        : globalCrop
          ? "当前状态使用统一裁剪，可保存单张微调覆盖。"
          : "调整裁剪框后保存为统一裁剪。";
      cropperImage.src = url;
      cropper = new Cropper(cropperImage, {
        viewMode: 1,
        autoCropArea: 0.82,
        background: false,
        responsive: true,
        restore: false,
        aspectRatio: Number(outputWidthInput.value || 1024) / Number(outputHeightInput.value || 1024),
        ready() {
          const preferred = cropOverrides[activeState] || globalCrop;
          const data = ratioToData(preferred, activeState);
          if (data) cropper.setData(data);
          updatePreview(previewState);
        },
        crop() {
          window.clearTimeout(window.fridayPreviewTimer);
          window.fridayPreviewTimer = window.setTimeout(() => updatePreview(previewState), 120);
        }
      });
    }

    function loadImage(url) {
      return new Promise((resolve, reject) => {
        const image = new Image();
        image.onload = () => resolve(image);
        image.onerror = reject;
        image.src = url;
      });
    }

    async function renderStateCanvas(state) {
      const url = sourceUrls[state];
      if (!url) return null;
      const image = await loadImage(url);
      const { width, height } = outputSize();
      const canvas = document.createElement("canvas");
      canvas.width = width;
      canvas.height = height;
      const context = canvas.getContext("2d");
      context.clearRect(0, 0, width, height);

      const ratio = cropOverrides[state] || globalCrop || { x: 0, y: 0, width: 1, height: 1 };
      const sx = Math.max(0, ratio.x * image.naturalWidth);
      const sy = Math.max(0, ratio.y * image.naturalHeight);
      const sw = Math.min(image.naturalWidth - sx, ratio.width * image.naturalWidth);
      const sh = Math.min(image.naturalHeight - sy, ratio.height * image.naturalHeight);
      context.imageSmoothingQuality = "high";
      context.drawImage(image, sx, sy, sw, sh, 0, 0, width, height);
      return canvas;
    }

    async function updatePreview(state = previewState) {
      const version = ++previewVersion;
      previewState = state;
      document.querySelectorAll(".preview-state").forEach((button) => {
        button.classList.toggle("border-leaf", button.dataset.state === state);
        button.classList.toggle("text-leaf", button.dataset.state === state);
      });
      const canvas = await renderStateCanvas(state);
      if (version !== previewVersion) return;
      if (!canvas) {
        if (previewObjectUrl) {
          URL.revokeObjectURL(previewObjectUrl);
          previewObjectUrl = "";
        }
        petPreview.removeAttribute("src");
        petPreview.classList.add("hidden");
        previewEmpty.classList.remove("hidden");
        return;
      }
      canvas.toBlob((blob) => {
        if (version !== previewVersion) return;
        if (!blob) return;
        if (previewObjectUrl) URL.revokeObjectURL(previewObjectUrl);
        previewObjectUrl = URL.createObjectURL(blob);
        petPreview.src = previewObjectUrl;
        petPreview.classList.remove("hidden");
        previewEmpty.classList.add("hidden");
      }, "image/png");
    }

    function updateStatus() {
      const uploaded = uploadedStates();
      const missing = missingStates();
      uploadCount.textContent = `${uploaded.length} / ${states.length}`;
      missingStatus.textContent = missing.length ? `${missing.length} 个状态未上传` : "状态已完整";
      globalCropStatus.textContent = globalCrop ? "已保存统一裁剪" : "尚未保存";
      downloadZip.disabled = missing.length > 0;
      downloadHint.textContent = missing.length
        ? `还缺少：${missing.map((state) => `_${state}_`).join("、")}`
        : `将下载 ${folderName()}.zip，可直接解压后在 Friday 中选择该文件夹。`;
      activeStateStatus.textContent = cropOverrides[activeState] ? `${activeState}（已单张微调）` : activeState;
      clearStateCrop.disabled = !cropOverrides[activeState];
      clearAllImages.disabled = uploaded.length === 0;
    }

    function updateStateCard(state) {
      const card = document.querySelector(`.state-card[data-state="${state}"]`);
      if (!card) return;
      const status = card.querySelector(".state-status");
      const thumb = card.querySelector(".state-thumb");
      const empty = card.querySelector(".state-empty");
      const clearButton = card.querySelector(".clear-state");
      if (files[state]) {
        status.textContent = cropOverrides[state] ? "已微调" : "已上传";
        status.className = "state-status rounded-full bg-mint px-2 py-1 text-xs font-semibold text-leaf";
        thumb.src = sourceUrls[state];
        thumb.classList.remove("hidden");
        empty.classList.add("hidden");
        clearButton.disabled = false;
      } else {
        status.textContent = "缺失";
        status.className = "state-status rounded-full bg-white px-2 py-1 text-xs font-semibold text-ink/45";
        thumb.removeAttribute("src");
        thumb.classList.add("hidden");
        empty.classList.remove("hidden");
        clearButton.disabled = true;
      }
    }

    function updateAllStateCards() {
      states.forEach(updateStateCard);
    }

    async function handleFile(state, file) {
      if (!file) return;
      files[state] = file;
      if (sourceUrls[state]) URL.revokeObjectURL(sourceUrls[state]);
      sourceUrls[state] = URL.createObjectURL(file);
      const image = await loadImage(sourceUrls[state]);
      imageSizes[state] = { width: image.naturalWidth, height: image.naturalHeight };
      if (!globalCrop && state === "Idle") {
        globalCrop = { x: 0, y: 0, width: 1, height: 1 };
      }
      updateStateCard(state);
      updateStatus();
      setActiveState(state);
      updatePreview(state);
    }

    function clearStateImage(state) {
      if (!files[state] && !sourceUrls[state] && !cropOverrides[state]) return;
      delete files[state];
      delete imageSizes[state];
      delete cropOverrides[state];
      if (sourceUrls[state]) URL.revokeObjectURL(sourceUrls[state]);
      delete sourceUrls[state];

      const input = document.querySelector(`.state-input[data-state="${state}"]`);
      if (input) input.value = "";
      if (!uploadedStates().length) globalCrop = null;

      updateStateCard(state);
      updateStatus();
      if (activeState === state) loadCropperForActiveState();
      if (previewState === state) updatePreview(state);
    }

    function clearAllStateImages() {
      states.forEach((state) => {
        if (sourceUrls[state]) URL.revokeObjectURL(sourceUrls[state]);
        delete files[state];
        delete sourceUrls[state];
        delete imageSizes[state];
        delete cropOverrides[state];
        const input = document.querySelector(`.state-input[data-state="${state}"]`);
        if (input) input.value = "";
      });
      globalCrop = null;
      updateAllStateCards();
      updateStatus();
      loadCropperForActiveState();
      updatePreview(previewState);
    }

    async function downloadCharacterZip() {
      const missing = missingStates();
      if (missing.length) return;
      const zip = new JSZip();
      const folder = zip.folder(folderName());
      downloadZip.disabled = true;
      downloadZip.textContent = "正在打包...";
      try {
        for (const state of states) {
          const canvas = await renderStateCanvas(state);
          const blob = await new Promise((resolve) => canvas.toBlob(resolve, "image/png"));
          folder.file(`_${state}_.png`, blob);
        }
        const blob = await zip.generateAsync({ type: "blob" });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = `${folderName()}.zip`;
        document.body.append(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
      } finally {
        downloadZip.textContent = "下载角色 zip";
        updateStatus();
      }
    }

    document.querySelectorAll(".state-input").forEach((input) => {
      input.addEventListener("change", (event) => {
        const target = event.currentTarget;
        handleFile(target.dataset.state, target.files?.[0]);
      });
    });

    document.querySelectorAll(".state-select").forEach((button) => {
      button.addEventListener("click", () => setActiveState(button.dataset.state));
    });

    document.querySelectorAll(".clear-state").forEach((button) => {
      button.addEventListener("click", () => clearStateImage(button.dataset.state));
    });

    document.querySelectorAll(".preview-state").forEach((button) => {
      button.addEventListener("click", () => updatePreview(button.dataset.state));
    });

    roleNameInput.addEventListener("input", () => {
      updatePackageName();
      updateStatus();
    });

    function syncOutputInputs({ commit = false } = {}) {
      const { width, height } = outputSize();
      if (commit) {
        outputWidthInput.value = String(width);
        outputHeightInput.value = String(height);
      }
      updatePackageName();
      if (cropper) cropper.setAspectRatio(width / height);
      updatePreview(previewState);
    }

    [outputWidthInput, outputHeightInput].forEach((input) => {
      input.addEventListener("input", () => syncOutputInputs());
      input.addEventListener("change", () => syncOutputInputs({ commit: true }));
    });

    saveGlobalCrop.addEventListener("click", () => {
      const ratio = cropperDataToRatio();
      if (!ratio) return;
      globalCrop = ratio;
      updateStatus();
      updatePreview(previewState);
    });

    saveStateCrop.addEventListener("click", () => {
      const ratio = cropperDataToRatio();
      if (!ratio) return;
      cropOverrides[activeState] = ratio;
      updateStateCard(activeState);
      updateStatus();
      updatePreview(activeState);
    });

    clearStateCrop.addEventListener("click", () => {
      delete cropOverrides[activeState];
      updateStateCard(activeState);
      updateStatus();
      loadCropperForActiveState();
      updatePreview(activeState);
    });

    toggleAutoPreview.addEventListener("click", () => {
      if (autoTimer) {
        window.clearInterval(autoTimer);
        autoTimer = 0;
        toggleAutoPreview.textContent = "自动轮播";
        return;
      }
      toggleAutoPreview.textContent = "停止轮播";
      autoTimer = window.setInterval(() => {
        const available = uploadedStates();
        if (!available.length) return;
        const index = available.indexOf(previewState);
        updatePreview(available[(index + 1) % available.length]);
      }, 1100);
    });

    clearAllImages.addEventListener("click", clearAllStateImages);
    downloadZip.addEventListener("click", () => void downloadCharacterZip());

    updatePackageName();
    updateAllStateCards();
    updateStatus();
    setActiveState("Idle");
  </script>
</Layout>
