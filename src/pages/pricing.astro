---
import Layout from "../components/Layout.astro";
import friday from "../data/products/friday.json";
---

<Layout title="Pricing" description="Friday pricing for local features, bring-your-own-key AI, and future hosted AI." canonicalPath="/pricing">
  <section class="section-shell py-16">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-leaf">Pricing</p>
      <h1 class="mt-4 text-4xl font-semibold text-ink md:text-5xl">首版定价保持透明</h1>
      <p class="mt-5 text-base leading-7 text-ink/64">先免费分发本地能力和用户自填密钥模式。公司托管 AI 转发服务在协议、计费和数据处理流程完成后再开放。</p>
    </div>
    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {friday.plans.map((plan, index) => (
        <article class={`rounded-2xl border p-6 ${index === 1 ? "border-leaf bg-ink text-white shadow-soft" : "border-ink/10 bg-white text-ink"}`}>
          <h2 class="text-2xl font-semibold">{plan.name}</h2>
          <p class={`mt-2 text-3xl font-semibold ${index === 1 ? "text-moss" : "text-leaf"}`}>{plan.price}</p>
          <p class={`mt-4 text-sm leading-6 ${index === 1 ? "text-white/70" : "text-ink/64"}`}>{plan.description}</p>
          <ul class="mt-6 space-y-3">
            {plan.items.map((item) => <li class="text-sm">✓ {item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>
</Layout>
