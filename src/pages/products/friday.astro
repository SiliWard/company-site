---
import Layout from "../../components/Layout.astro";
import ButtonLink from "../../components/ButtonLink.astro";
import FridayExperience from "../../components/FridayExperience.astro";
import ProductMockup from "../../components/ProductMockup.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import FaqList from "../../components/FaqList.astro";
import friday from "../../data/products/friday.json";
import { getWindowsReleases, releasesUrl } from "../../data/releases";
import happyImage from "../../assets/friday/_Happy_.png";
import idleImage from "../../assets/friday/_Idle_.png";
import reminderImage from "../../assets/friday/_Reminder_.png";
import talkingImage from "../../assets/friday/_Talking_.png";
import thinkingImage from "../../assets/friday/_Thinking_.png";
import urgentImage from "../../assets/friday/_Urgent_.png";
import restImage from "../../assets/friday/_Rest_.png";
import sleepyImage from "../../assets/friday/_Sleepy_.png";

const latestRelease = (await getWindowsReleases())[0];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: friday.name,
  applicationCategory: "ProductivityApplication",
  operatingSystem: "Windows",
  softwareVersion: latestRelease.version,
  offers: { "@type": "Offer", price: "0", priceCurrency: "CNY" }
};

const workflow = [
  ["记录", "把一句自然语言先变成可确认的任务草案。"],
  ["确认", "用户确认后才写入待办，避免误记录。"],
  ["排程", "在日历里安排执行时间，而不只是记截止日期。"],
  ["复盘", "通过总结视图查看进展、风险和下一步重点。"]
];

const states = [
  ["Idle", "安静常驻桌面", idleImage.src],
  ["Talking", "接收快速记录", talkingImage.src],
  ["Thinking", "整理 AI 草案", thinkingImage.src],
  ["Happy", "任务推进反馈", happyImage.src],
  ["Reminder", "提醒事项到来", reminderImage.src],
  ["Urgent", "突出紧急任务", urgentImage.src],
  ["Rest", "低干扰陪伴", restImage.src],
  ["Sleepy", "减少视觉打扰", sleepyImage.src]
];

const installSteps = [
  ["下载安装包", "从 SiliWard 组织仓库的 GitHub Releases 获取 Windows x64 安装包。"],
  ["运行 exe", "按安装向导选择目录并完成安装。未签名版本可能出现 SmartScreen 提示。"],
  ["配置本地偏好", "启动 Friday 后配置提醒、主题色、AI 密钥和可选 Codex 工作流。"]
];
---

<Layout title={`${friday.name} - ${friday.tagline}`} description={friday.description} canonicalPath="/products/friday">
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />

  <section class="section-shell grid min-h-[calc(100vh-64px)] items-center gap-12 py-14 lg:grid-cols-[0.92fr_1.08fr]">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wider text-leaf">Friday for Windows</p>
      <h1 class="mt-4 max-w-3xl text-5xl font-semibold tracking-normal text-ink md:text-6xl">
        {friday.tagline}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-ink/68">{friday.description}</p>
      <p class="mt-3 text-sm font-semibold text-leaf">{friday.fullName}</p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <ButtonLink href={latestRelease.exe.url}>下载 Windows 版</ButtonLink>
        <ButtonLink href="/download" variant="secondary">查看版本历史</ButtonLink>
      </div>
      <div class="mt-5 grid max-w-xl gap-3 sm:grid-cols-3">
        {[
          ["Version", latestRelease.version],
          ["Platform", friday.platform],
          ["Installer", latestRelease.exe.sizeLabel]
        ].map(([label, value]) => (
          <div class="rounded-lg border border-ink/10 bg-white/76 p-3">
            <p class="text-xs font-semibold uppercase tracking-wider text-ink/40">{label}</p>
            <p class="mt-1 break-words text-sm font-semibold text-ink">{value}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="relative overflow-hidden rounded-lg border border-ink/10 bg-white p-6 shadow-soft">
      <div class="absolute left-5 top-5 z-10 rounded-lg border border-ink/10 bg-white/90 px-3 py-2 text-sm font-semibold text-ink shadow-sm">
        今天 4 个任务待处理
      </div>
      <div class="absolute bottom-6 right-6 z-10 rounded-lg border border-leaf/20 bg-mint px-3 py-2 text-sm font-semibold text-leaf shadow-sm">
        15:00 提醒已设置
      </div>
      <div class="grid min-h-[520px] place-items-center rounded-lg bg-cloud">
        <img class="w-[min(340px,72%)] drop-shadow-2xl" src={happyImage.src} alt="Friday desktop pet happy state" />
      </div>
    </div>
  </section>

  <FridayExperience />

  <section class="bg-white py-20">
    <div class="section-shell">
      <SectionHeading eyebrow="Workflow" title="从一句话到一天的计划" text="Friday 的核心不是把任务堆进列表，而是让记录、确认、排程和复盘形成一个低摩擦闭环。" />
      <div class="mt-10 grid gap-4 md:grid-cols-4">
        {workflow.map(([title, text], index) => (
          <article class="rounded-lg border border-ink/10 bg-cloud p-5">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-leaf text-sm font-semibold text-white">{index + 1}</span>
            <h2 class="mt-5 text-xl font-semibold text-ink">{title}</h2>
            <p class="mt-3 text-sm leading-6 text-ink/64">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell py-20">
    <SectionHeading eyebrow="Workspace" title="功能保持聚焦，但覆盖完整桌面工作流" text="公开版默认关闭敏感能力，用户可以按需开启全局选区、AI 密钥和 Codex 工作流。" />
    <div class="mt-10 grid gap-8 lg:grid-cols-[1fr_1.05fr] lg:items-center">
      <ProductMockup />
      <div class="grid gap-4 sm:grid-cols-2">
        {friday.features.map((feature) => (
          <article class="rounded-lg border border-ink/10 bg-white p-5 shadow-sm">
            <h2 class="text-lg font-semibold text-ink">{feature.title}</h2>
            <p class="mt-3 text-sm leading-6 text-ink/64">{feature.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="section-shell">
      <SectionHeading eyebrow="Pet states" title="让桌面助手有清晰状态反馈" text="参考桌宠产品页的表现方式，Friday 在记录、思考、提醒和任务推进时展示不同状态，用户不需要打开大窗口也能理解当前上下文。" />
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {states.map(([name, text, image]) => (
          <article class="rounded-lg border border-ink/10 bg-cloud p-4 text-center">
            <img class="mx-auto h-40 w-full object-contain drop-shadow-xl" src={image} alt={`Friday ${name} state`} />
            <h2 class="mt-4 text-lg font-semibold text-ink">{name}</h2>
            <p class="mt-2 text-sm leading-6 text-ink/60">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell py-20">
    <SectionHeading eyebrow="Trust" title="AI 能力由用户控制数据路径" text="首版默认支持用户自填模型密钥。未来托管 AI 服务上线前，会补齐独立的数据处理、计费和删除请求流程。" />
    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {[
        ["本地优先", "待办、提醒、设置和会话历史默认保存在本机应用数据目录。"],
        ["密钥加密", "API key 使用系统安全存储能力保存，不写入主 JSON 数据文件。"],
        ["权限分离", "全局选区和 Codex 默认关闭，开启前展示具体能力和风险。"]
      ].map(([title, text]) => (
        <div class="rounded-lg border border-ink/10 bg-white p-6">
          <h2 class="text-xl font-semibold text-ink">{title}</h2>
          <p class="mt-3 text-sm leading-6 text-ink/64">{text}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="section-shell">
      <SectionHeading eyebrow="Install" title="三步开始使用 Friday" text="安装包随 GitHub Releases 发布，下载页会同步展示最新版本和历史版本。" />
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {installSteps.map(([title, text], index) => (
          <article class="rounded-lg border border-ink/10 bg-cloud p-5">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-ink text-sm font-semibold text-white">{index + 1}</span>
            <h2 class="mt-5 text-xl font-semibold text-ink">{title}</h2>
            <p class="mt-3 text-sm leading-6 text-ink/64">{text}</p>
          </article>
        ))}
      </div>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <ButtonLink href={latestRelease.exe.url}>下载 {latestRelease.exe.name}</ButtonLink>
        <ButtonLink href={releasesUrl} variant="secondary">打开 GitHub Releases</ButtonLink>
      </div>
    </div>
  </section>

  <section class="section-shell py-20">
    <SectionHeading eyebrow="Pricing" title="先免费分发，AI 服务分层说明" text="免费功能和用户自填密钥能力可以先上线；公司托管转发只作为即将推出，不承诺未完成能力。" />
    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {friday.plans.map((plan, index) => (
        <article class={`rounded-lg border p-6 ${index === 1 ? "border-leaf bg-ink text-white shadow-soft" : "border-ink/10 bg-white text-ink"}`}>
          <h2 class="text-2xl font-semibold">{plan.name}</h2>
          <p class={`mt-2 text-3xl font-semibold ${index === 1 ? "text-moss" : "text-leaf"}`}>{plan.price}</p>
          <p class={`mt-4 text-sm leading-6 ${index === 1 ? "text-white/70" : "text-ink/64"}`}>{plan.description}</p>
          <ul class="mt-6 space-y-3">
            {plan.items.map((item) => (
              <li class={`text-sm ${index === 1 ? "text-white/76" : "text-ink/68"}`}>✓ {item}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section-shell py-20">
    <SectionHeading eyebrow="FAQ" title="上线前用户最关心的问题" />
    <div class="mt-10">
      <FaqList items={friday.faq} />
    </div>
  </section>
</Layout>
